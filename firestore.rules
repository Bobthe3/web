rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Posts: public read for published non-private posts, admin write
    match /posts/{postId} {
      allow read: if resource.data.isPublished == true && resource.data.isPrivate == false;
      allow write: if request.auth != null && request.auth.token.email == 'OWNER_EMAIL';
    }

    // Books: public read, admin write
    match /books/{bookId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'OWNER_EMAIL';
    }

    // Access links: no public read (only via Cloud Functions), admin write
    match /access_links/{linkId} {
      allow read: if false;
      allow write: if request.auth != null && request.auth.token.email == 'OWNER_EMAIL';
    }

    // Link events: anyone can create (tracking), admin can read
    match /link_events/{eventId} {
      allow create: if true;
      allow read: if request.auth != null && request.auth.token.email == 'OWNER_EMAIL';
      allow update, delete: if false;
    }
  }
}
